# Exemplo de configuração de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus dados reais

# Django
DEBUG=False
SECRET_KEY=sua-chave-secreta-aqui
ALLOWED_HOSTS=localhost,127.0.0.1,sua-app.railway.app

# Banco de Dados (deixe vazio para usar SQLite local)
DATABASE_URL=

# Mercado Pago
MP_PUBLIC_KEY=sua-chave-publica
MP_ACCESS_TOKEN=seu-token-de-acesso

# Resend (E-mail)
RESEND_API_KEY=sua-api-key-do-resend
